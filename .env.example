# niuma-cheng-workboard 环境变量模板（v0.2）
# 复制为 .env 后按环境填写；.env 已在 .gitignore，不入库。

# ── PostgreSQL 连接（IRC-001，必填）────────────────────────────
# 本地开发：经 SSH 隧道连服务器 PG（PG_PORT 填隧道本地端口，如 15432）
# 服务器部署：直连本机 PG（PG_PORT=5432）
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=workboard

# ── 远程会话源（IRC-002/003，可选）────────────────────────────
# 逗号分隔的 SSH 别名，同步时 rsync 拉取远程 ~/.claude/projects 与 ~/.codex/sessions。
# 依赖 ~/.ssh/config 预先配置好 Host 别名 + 免密登录（如 Host zijie ...）。
# 未配置则只同步本机会话；服务器部署通常留空（只同步自己本机）。
# 例：CLAUDE_REMOTE_SOURCES=zijie
CLAUDE_REMOTE_SOURCES=

# ── HTTP 服务（可选，有默认值）────────────────────────────────
# PORT=5174
# HOST=0.0.0.0
