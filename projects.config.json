{
  "ecosystem": {
    "name": "niuma-cheng 生态",
    "root_path": "..",
    "claude_project_id": ["-Users-ck-Project-niuma-cheng", "-root-Project"]
  },
  "refresh": {
    "interval_seconds": 60
  },
  "projects": [
    {
      "id": "workflow",
      "name": "agent-workflow（框架真源）",
      "path": "../agent-workflow",
      "kind": "workflow-source",
      "enabled": true,
      "claude_project_id": ["-Users-ck-Project-niuma-cheng-agent-workflow", "-root-Project-agent-workflow"]
    },
    {
      "id": "xiaobao",
      "name": "牛马程小报",
      "path": "../niuma-cheng-xiaobao",
      "kind": "business",
      "enabled": true,
      "url": "https://news.huiyiyou.cloud",
      "claude_project_id": ["-Users-ck-Project-niuma-cheng-niuma-cheng-xiaobao", "-root-Project-niuma-cheng-xiaobao"]
    },
    {
      "id": "ai",
      "name": "AI 处理中枢",
      "path": "../niuma-cheng-ai",
      "kind": "business",
      "enabled": true,
      "claude_project_id": ["-Users-ck-Project-niuma-cheng-niuma-cheng-ai", "-root-Project-niuma-cheng-ai"]
    },
    {
      "id": "coordination",
      "name": "公告板（coordination）",
      "path": "../niuma-cheng-coordination",
      "kind": "coordination",
      "enabled": true,
      "claude_project_id": ["-Users-ck-Project-niuma-cheng-niuma-cheng-coordination", "-root-Project-niuma-cheng-coordination"]
    },
    {
      "id": "workboard",
      "name": "项目管理工作台",
      "path": ".",
      "kind": "workboard",
      "enabled": true,
      "claude_project_id": ["-Users-ck-Project-niuma-cheng-niuma-cheng-workboard", "-root-Project-niuma-cheng-workboard"]
    }
  ],
  "coordination": {
    "project_id": "coordination"
  }
}
